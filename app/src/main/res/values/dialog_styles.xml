<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Dialog theme — matches design-screens-v3 -->
    <style name="CustomDialogTheme" parent="Theme.AppCompat.Dialog.Alert">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:background">@drawable/dialog_background</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="colorAccent">@color/white</item>
        <item name="buttonBarNegativeButtonStyle">@style/CustomDialogButton</item>
        <item name="buttonBarPositiveButtonStyle">@style/CustomDialogButton</item>
    </style>

    <style name="CustomDialogButton" parent="Widget.AppCompat.Button.ButtonBar.AlertDialog">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="CustomDialogEditText">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_placeholder</item>
        <item name="android:textSize">13sp</item>
        <item name="android:background">@drawable/card_field_bg</item>
        <item name="android:padding">10dp</item>
    </style>
</resources>
