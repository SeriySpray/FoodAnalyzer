<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Recipemanager" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/white</item>
        <item name="colorPrimaryVariant">@color/surface_elevated</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">@color/white</item>
        <item name="colorSecondaryVariant">@color/surface</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:colorBackground">@color/black</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnBackground">@color/white</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="android:statusBarColor">@color/status_bar</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/status_bar</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:enforceNavigationBarContrast">false</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="colorControlActivated">@color/white</item>
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
    </style>

    <!-- Buttons — 48dp touch targets, 14sp text -->
    <style name="PrimaryButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/button_background</item>
        <item name="android:textColor">@color/button_text</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0</item>
        <item name="elevation">0dp</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="SecondaryButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="backgroundTint">@color/surface</item>
        <item name="strokeColor">@color/border_subtle</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="android:letterSpacing">0</item>
        <item name="elevation">0dp</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="DangerButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="backgroundTint">@color/surface</item>
        <item name="strokeColor">#4D2020</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">#CC4444</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="android:letterSpacing">0</item>
        <item name="elevation">0dp</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="CustomEditText" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/surface</item>
        <item name="boxStrokeColor">@color/border</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">1dp</item>
        <item name="boxCornerRadiusTopStart">10dp</item>
        <item name="boxCornerRadiusTopEnd">10dp</item>
        <item name="boxCornerRadiusBottomStart">10dp</item>
        <item name="boxCornerRadiusBottomEnd">10dp</item>
        <item name="hintTextColor">@color/text_muted</item>
        <item name="android:textColorHint">@color/text_muted</item>
    </style>

    <style name="CustomEditTextInput">
        <item name="android:textCursorDrawable">@null</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="RecipeCard">
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="cardCornerRadius">10dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/border</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="CalendarDateTextAppearance" parent="TextAppearance.AppCompat.Small">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="CalendarWeekDayTextAppearance" parent="TextAppearance.AppCompat.Small">
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textSize">11sp</item>
    </style>

    <style name="SectionLabel">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="FieldLabel">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.04</item>
    </style>

    <!-- Custom PopupMenu — matches app style -->
    <style name="AppPopupMenu" parent="Widget.MaterialComponents.PopupMenu">
        <item name="android:popupBackground">@drawable/menu_panel_bg</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="PopupThemeOverlay" parent="ThemeOverlay.MaterialComponents.Light">
        <item name="popupMenuStyle">@style/AppPopupMenu</item>
        <item name="android:popupMenuStyle">@style/AppPopupMenu</item>
        <item name="android:itemTextAppearance">@style/PopupMenuItemText</item>
    </style>

    <style name="PopupMenuItemText" parent="TextAppearance.AppCompat.Menu">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

</resources>
