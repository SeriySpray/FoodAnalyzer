<?xml version="1.0" encoding="utf-8"?>
<!-- Пошук — design-screens-v3 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/black"
    android:fitsSystemWindows="true"
    tools:context=".ui.search.SearchActivity">

    <!-- Search field -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/card_field_bg"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="10dp">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_search"
                android:layout_marginEnd="8dp"
                xmlns:app="http://schemas.android.com/apk/res-auto"
                app:tint="@color/text_dim" />

            <EditText
                android:id="@+id/searchEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:hint="@string/search_hint"
                android:textColorHint="@color/text_dim"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:background="@null"
                android:padding="0dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Filter chips -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/chipSearchAll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/chip_bg"
            android:paddingHorizontal="12dp"
            android:paddingVertical="5dp"
            android:layout_marginEnd="6dp"
            android:text="@string/search_complex"
            android:textColor="@color/text_tertiary"
            android:textSize="11sp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/chipSearchName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/chip_bg"
            android:paddingHorizontal="12dp"
            android:paddingVertical="5dp"
            android:layout_marginEnd="6dp"
            android:text="@string/search_by_name"
            android:textColor="@color/text_tertiary"
            android:textSize="11sp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/chipSearchIngredients"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/chip_bg"
            android:paddingHorizontal="12dp"
            android:paddingVertical="5dp"
            android:text="@string/search_by_ingredients"
            android:textColor="@color/text_tertiary"
            android:textSize="11sp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- Results list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/searchResultsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="16dp"
        android:clipToPadding="false"
        tools:listitem="@layout/item_recipe" />

    <TextView
        android:id="@+id/noResultsTextView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="Нічого не знайдено.\nСпробуйте інший запит."
        android:textColor="@color/text_secondary"
        android:textSize="18sp"
        android:lineSpacingExtra="6dp"
        android:paddingHorizontal="32dp"
        android:visibility="gone" />

    <!-- Hidden compat views -->
    <View android:id="@+id/searchInputLayout" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <View android:id="@+id/searchTypeChipGroup" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />

</LinearLayout>