<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:fitsSystemWindows="true"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top bar: Back + Edit -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_weight="0"
                android:background="@drawable/icon_btn_bg"
                android:src="@drawable/ic_arrow_back"
                android:scaleType="centerInside"
                android:padding="8dp"
                android:tint="@color/text_secondary"
                android:contentDescription="Назад" />

            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

            <ImageButton
                android:id="@+id/editButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/icon_btn_bg"
                android:src="@drawable/ic_edit"
                android:padding="10dp"
                android:scaleType="fitCenter"
                android:tint="@color/text_tertiary"
                android:contentDescription="Редагувати рецепт" />
        </LinearLayout>

        <!-- Recipe name -->
        <TextView
            android:id="@+id/recipeNameTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="4dp"
            tools:text="Борщ" />

        <!-- Meta line -->
        <TextView
            android:id="@+id/metaTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_muted"
            android:textSize="13sp"
            android:layout_marginBottom="14dp"
            tools:text="45 хв · Середній" />

        <!-- КБЖВ pills row -->
        <LinearLayout
            android:id="@+id/nutritionLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:background="@drawable/kbzu_pill_bg"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="6dp">
                <TextView
                    android:id="@+id/caloriesTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    tools:text="320" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ккал"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="2dp"
                android:background="@drawable/kbzu_pill_bg"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="6dp">
                <TextView
                    android:id="@+id/proteinsTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#4CAF50"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    tools:text="12г" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="білки"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="2dp"
                android:background="@drawable/kbzu_pill_bg"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="6dp">
                <TextView
                    android:id="@+id/fatsTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FF9800"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    tools:text="8г" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="жири"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:background="@drawable/kbzu_pill_bg"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="6dp">
                <TextView
                    android:id="@+id/carbsTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#2196F3"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    tools:text="45г" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="вугл."
                    android:textColor="@color/text_muted"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- КБЖВ Chart -->
        <LinearLayout
            android:id="@+id/nutritionChartLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_field_bg"
            android:orientation="vertical"
            android:padding="14dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="РОЗПОДІЛ НУТРІЄНТІВ"
                style="@style/FieldLabel"
                android:layout_marginBottom="4dp" />

            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/nutritionPieChart"
                android:layout_width="match_parent"
                android:layout_height="260dp" />
        </LinearLayout>

        <!-- Ingredients -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_field_bg"
            android:orientation="vertical"
            android:padding="14dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ІНГРЕДІЄНТИ"
                style="@style/FieldLabel"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/ingredientsTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"
                tools:text="Буряк, картопля, м'ясо" />
        </LinearLayout>

        <!-- Instructions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_field_bg"
            android:orientation="vertical"
            android:padding="14dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ІНСТРУКЦІЇ"
                style="@style/FieldLabel"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/instructionsTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:lineSpacingExtra="6dp"
                tools:text="Варити буряк 40 хв..." />
        </LinearLayout>

        <!-- Cooking counter -->
        <LinearLayout
            android:id="@+id/cookingCounterLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/card_field_bg"
            android:padding="14dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/times_cooked_label"
                android:textColor="@color/text_muted"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/decrementButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:gravity="center"
                android:text="−"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/cookingCounterTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium"
                android:minWidth="32dp"
                android:gravity="center"
                tools:text="3" />

            <TextView
                android:id="@+id/incrementButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:gravity="center"
                android:text="+"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Delete button -->
        <Button
            android:id="@+id/deleteButton"
            style="@style/DangerButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Видалити рецепт" />

        <!-- Hidden views for code compat -->
        <TextView
            android:id="@+id/cookingTimeTextView"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/difficultyTextView"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
