<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Recipemanager" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/white</item>
        <item name="colorPrimaryVariant">@color/surface_elevated</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">@color/white</item>
        <item name="colorSecondaryVariant">@color/surface</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:colorBackground">@color/black</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnBackground">@color/white</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="android:statusBarColor">@color/black</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/black</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:enforceNavigationBarContrast">false</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="colorControlActivated">@color/white</item>
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
    </style>

    <style name="PopupThemeOverlay" parent="ThemeOverlay.MaterialComponents.Dark">
        <item name="popupMenuStyle">@style/AppPopupMenu</item>
        <item name="android:popupMenuStyle">@style/AppPopupMenu</item>
        <item name="android:itemTextAppearance">@style/PopupMenuItemText</item>
    </style>
</resources>
